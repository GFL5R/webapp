    "Irresistible Flirt": {
        type: ["Social"],
        flavor: """
            <p><em>The supply depot clerk had heard every line. She'd been stationed at this checkpoint for six months, processing requisitions for contractors who all thought they were charming. She was immune. Or she thought she was.</em></p>
            <p>"Requisition for 5.56 NATO, four cases. Sign here."</p>
