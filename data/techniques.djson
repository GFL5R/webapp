  "Defensive Maneuver": {
    rank: 1,
    type: "Combat",
    approach: "Resilience",
    skill: null,
    flavor: "Sometimes all else fails and you take a nasty hit. Twisting your body, raising an arm, anything to deflect the blow just enough to avoid the worst of it separates a survivor from a casualty.",
    description: """
