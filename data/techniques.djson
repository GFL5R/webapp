  Overclock: {
    rank: 1,
    type: "Electronic Warfare",
    approach: null,
    skill: null,
    flavor: "Every piece of hardware ships with safety margins built in. Conservative firmware, thermal limits, voltage caps. Stripping those out is the easiest upgrade in the world. It is also the fastest way to burn through a deck you cannot afford to replace.",
    description: """
      <h3>Activation:</h3>
      <p>As a Support action, no check required.</p>
