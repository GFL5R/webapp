  Hijack: {
    rank: 2,
    type: "Electronic Warfare",
    approach: null,
    skill: "Computers",
    flavor: "A locked door is an obstacle. A locked door you control is a weapon. Turrets, drones, environmental systems: every networked device is a tool waiting for someone with the nerve and the skill to pick it up and use it.",
    description: """
      <h3>Activation:</h3>
      <p>As a Scheme action, make a <strong>Computers check</strong> at the network's TN, targeting one device on a node where you hold a foothold.</p>
