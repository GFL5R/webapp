  "Deflective Defense": {
    rank: 3,
    type: "Combat",
    approach: "Resilience",
    skill: "Blades",
    flavor: "Normally relegated to anime and B-tier action movies, deflecting bullets with a blade is a fantasy held by many an aspiring sword user. Actually pulling it off is a feat worthy of legend.",
    description: """
      <h3>Activation:</h3>
